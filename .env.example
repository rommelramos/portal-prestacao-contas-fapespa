# ==========================================================================
# Portal de Prestação de Contas FAPESPA — variáveis de ambiente
# Copie para .env (NUNCA versionar .env) e preencha. No Vercel, cadastrar
# todas estas como "Environment Variables" sensíveis.
# ==========================================================================

# Banco MySQL (HostGator). connection_limit baixo: hospedagem compartilhada
# tem max_connections reduzido e o Vercel é serverless.
DATABASE_URL="mysql://rommel34_prestacao:SENHA_AQUI@69.6.249.192:3306/rommel34_prestacao?connection_limit=5&connect_timeout=20"

# Auth.js — segredo para assinar os tokens de sessão (JWT).
# Gere com: npx auth secret   (ou)   openssl rand -base64 32
AUTH_SECRET="gerar_um_segredo_forte"

# URL pública da aplicação (no Vercel, a URL do deploy).
AUTH_URL="http://localhost:3000"

# API da Anthropic (chatbot Claude).
ANTHROPIC_API_KEY="sk-ant-..."

# Voyage AI — embeddings para o RAG (banco vetorial).
VOYAGE_API_KEY="pa-..."
VOYAGE_MODEL="voyage-3.5"

# Vercel Blob — armazenamento dos PDFs (injetado automaticamente ao vincular o store).
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Expiração de sessão por inatividade, em minutos (RF003). Padrão: 60.
SESSION_TIMEOUT_MINUTES="60"

# Envio de e-mail (recuperação de senha — RF002). Sem a chave, o link é apenas
# registrado no log do servidor. O remetente precisa de domínio verificado no Resend.
RESEND_API_KEY="re_..."
RESEND_FROM="Portal de Prestação de Contas <nao-responda@seu-dominio.com.br>"

# (Opcional) Dados do admin inicial criado pelo seed.
SEED_ADMIN_NAME="Administrador ISACI"
SEED_ADMIN_EMAIL="admin@isaci.org.br"
SEED_ADMIN_PASSWORD="troque_esta_senha"
